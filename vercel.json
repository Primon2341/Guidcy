{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/browse", "destination": "/index.html" },
    { "source": "/categories", "destination": "/index.html" },
    { "source": "/become-a-consultant", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/signup", "destination": "/index.html" },
    { "source": "/profile", "destination": "/index.html" },
    { "source": "/payment", "destination": "/index.html" },
    { "source": "/confirm", "destination": "/index.html" },
    { "source": "/review", "destination": "/index.html" },
    { "source": "/meeting", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/faq", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/refund", "destination": "/index.html" },
    { "source": "/disclaimer", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/consultant-dashboard", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/pages/search", "destination": "/index.html" },
    { "source": "/account/register", "destination": "/index.html" }
  ]
}
