{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(favicon.ico|favicon.svg|favicon.png|favicon-16x16.png|favicon-32x32.png|favicon-48x48.png|favicon-96x96.png|favicon-180x180.png|favicon-192x192.png|favicon-512x512.png|apple-touch-icon.png|site.webmanifest|manifest.json|robots.txt|sitemap.xml|logo.png|logo.jpeg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|favicon.ico|favicon.svg|favicon.png|favicon-16x16.png|favicon-32x32.png|favicon-48x48.png|favicon-96x96.png|favicon-180x180.png|favicon-192x192.png|favicon-512x512.png|apple-touch-icon.png|site.webmanifest|manifest.json|robots.txt|sitemap.xml|logo.png|logo.jpeg).*)",
      "destination": "/index.html"
    }
  ]
}